<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <!-- NET8 builder is adding by default +to versioncommit https://github.com/dotnet/sdk/issues/34568 -->
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>

    <!-- AssemblyInfo.cs -->
    <Authors>Original Authors of IonicZip, DotNetZip and others</Authors>
    <Product>ProDotNetZipJ</Product>
    <Title>ProDotNetZipJ NET Standard</Title>
    <AssemblyDescription>ProDotNetZipJ NET Standard (fork of ProDotNetZip / DotNetZip / Ionic's Zip Library) a library for handling zip archives.</AssemblyDescription>
    <AssemblyVersion>1.20.2.0</AssemblyVersion>
    <Version>1.20.2.0</Version>
    <FileVersion>1.20.2.0</FileVersion>
    <InformationalVersion>1.20.2.0</InformationalVersion>

    <NeutralLanguage>en-US</NeutralLanguage>
  </PropertyGroup>
</Project>
